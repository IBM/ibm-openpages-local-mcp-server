# OpenPages Configuration
# Replace with your OpenPages instance URL (include protocol https://)
OPENPAGES_BASE_URL=

# Authentication settings - use either basic or bearer authentication
# Options: 'basic' or 'bearer'
OPENPAGES_AUTHENTICATION_TYPE=bearer

# For basic authentication (required if OPENPAGES_AUTHENTICATION_TYPE=basic):
OPENPAGES_USERNAME=
OPENPAGES_PASSWORD=

# For bearer authentication (required if OPENPAGES_AUTHENTICATION_TYPE=bearer):
# The system automatically detects IBM Cloud vs MCSP based on the authentication URL:
# - IBM Cloud: URLs containing 'iam.cloud.ibm.com' or 'iam.test.cloud.ibm.com'
# - MCSP: URLs containing 'account-iam.platform' or 'saas.ibm.com'

# Example for IBM Cloud OAuth2:
# OPENPAGES_APIKEY=your_ibm_cloud_api_key_here
# OPENPAGES_AUTHENTICATION_URL=https://iam.cloud.ibm.com/identity/token
# For test environment: https://iam.test.cloud.ibm.com/identity/token

# Example for MCSP OAuth2:
# OPENPAGES_APIKEY=apikey
# OPENPAGES_AUTHENTICATION_URL=https://account-iam.platform.test.saas.ibm.com/api/2.0/services/{service_id}/apikeys/token
# For production: https://account-iam.platform.saas.ibm.com/api/2.0/services/{service_id}/apikeys/token

OPENPAGES_APIKEY=
OPENPAGES_AUTHENTICATION_URL=

# Server Configuration
# Set to True for development, False for production
DEBUG=False

# SSL verification for API calls
# Set to False only for development with self-signed certificates
SSL_VERIFY=True

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Server port and host
PORT=8000
HOST=0.0.0.0
